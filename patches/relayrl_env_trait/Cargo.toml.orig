[package]
name = "relayrl_env_trait"
version = "1.1.0"
edition = "2024"
description = "Traits for training and testing environments in the RelayRL framework."
repository = "https://github.com/jrcalgo/relayrl"
documentation = "https://docs.rs/crate/relayrl_env_trait"
keywords = ['environment', 'integration', 'deep-learning', 'ai', 'batching']
categories = ['science', 'algorithms', 'simulation', 'concurrency', 'mathematics']
license = "Apache-2.0"

[dependencies]
thiserror = { workspace = true }
uuid = { workspace = true }
burn-tensor = { workspace = true }