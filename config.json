{
    "client_config": {
        "algorithm_name": "PPO",
        "config_update_polling_seconds": 10.0,
        "init_hyperparameters": {
            "PPO": {
                "discrete": true,
                "seed": 0,
                "traj_per_epoch": 4,
                "clip_ratio": 0.1,
                "gamma": 0.99,
                "lam": 0.97,
                "pi_lr": 3e-4,
                "vf_lr": 3e-4,
                "train_pi_iters": 40,
                "train_v_iters": 40,
                "target_kl": 0.01
            },
            "REINFORCE": {
                "discrete": true,
                "with_vf_baseline": true,
                "seed": 1,
                "traj_per_epoch": 4,
                "gamma": 0.98,
                "lam": 0.97,
                "pi_lr": 3e-4,
                "vf_lr": 1e-3,
                "train_vf_iters": 80
            }
        },
        "trajectory_file_output": {
            "directory": "trajectories",
            "file_type": "Arrow"
        },
        "metrics_meter_name": "relayrl-client",
